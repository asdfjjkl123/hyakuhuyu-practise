Dialogue: 0,0:00:00.98,0:00:02.98,up,,0,0,0,,{\fs55\fad(300,300)}本字幕由百冬練習組製作 僅供學習交流使用 請勿用作商業行為
Comment: 0,0:00:00.98,0:00:01.06,OPJP,,0,0,0,,OP マジで世界変えちゃう 5 秒前
Dialogue: 0,0:00:02.61,0:00:05.90,OPJP,,0,0,0,,マジで世界変えちゃう5秒前！
Dialogue: 0,0:00:10.99,0:00:13.03,OPJP,,0,0,0,,青春だね　お花畑
Dialogue: 0,0:00:13.03,0:00:14.79,OPJP,,0,0,0,,実際はね　手垢だらけ
Dialogue: 0,0:00:14.79,0:00:16.45,OPJP,,0,0,0,,黄色のハンカチ吊るし
Dialogue: 0,0:00:16.45,0:00:17.83,OPJP,,0,0,0,,待つだけはナシ
Dialogue: 0,0:00:18.33,0:00:19.17,OPJP,,0,0,0,,よりどりみどり
Dialogue: 0,0:00:19.17,0:00:20.04,OPJP,,0,0,0,,巧妙カラクリ
Dialogue: 0,0:00:20.04,0:00:21.75,OPJP,,0,0,0,,アドリブがタブーなら既読スルー
Dialogue: 0,0:00:21.75,0:00:23.59,OPJP,,0,0,0,,桃太郎さん　桃太郎さん
Dialogue: 0,0:00:23.59,0:00:25.26,OPJP,,0,0,0,,交渉つけに日々談合
Dialogue: 0,0:00:25.26,0:00:26.80,OPJP,,0,0,0,,Bang！ 左からペロン
Dialogue: 0,0:00:26.80,0:00:28.34,OPJP,,0,0,0,,Bang！ 右からは世論
Dialogue: 0,0:00:28.34,0:00:30.05,OPJP,,0,0,0,,揺らいでいるオピニオン
Dialogue: 0,0:00:30.05,0:00:32.01,OPJP,,0,0,0,,脳内ワッショイ　解放宣言
Dialogue: 0,0:00:32.01,0:00:33.72,OPJP,,0,0,0,,どうなってくの？
Dialogue: 0,0:00:33.72,0:00:35.52,OPJP,,0,0,0,,やっちゃいますか！
Dialogue: 0,0:00:35.52,0:00:37.27,OPJP,,0,0,0,,全問正解　全然無理よ
Dialogue: 0,0:00:37.27,0:00:38.85,OPJP,,0,0,0,,自分は何者？ もういいよ
Dialogue: 0,0:00:38.85,0:00:40.69,OPJP,,0,0,0,,この感情が正義だろうが
Dialogue: 0,0:00:40.69,0:00:42.36,OPJP,,0,0,0,,逆襲 Show Time
Dialogue: 0,0:00:42.36,0:00:44.11,OPJP,,0,0,0,,意地悪ばっか　ひっかけ問題
Dialogue: 0,0:00:44.11,0:00:45.65,OPJP,,0,0,0,,優勝者とかどうでもいいよ
Dialogue: 0,0:00:45.65,0:00:48.57,OPJP,,0,0,0,,教えてあげる
Dialogue: 0,0:00:49.07,0:00:52.03,OPJP,,0,0,0,,視聴率　気にし過ぎてた
Dialogue: 0,0:00:52.53,0:00:55.87,OPJP,,0,0,0,,今　曖昧な心を爆破する
Dialogue: 0,0:00:55.87,0:00:59.08,OPJP,,0,0,0,,マジで世界変えちゃう5秒前！
Dialogue: 0,0:00:59.46,0:01:01.29,OPJP,,0,0,0,,崩壊ドンマイ　ひっちゃかめっちゃか
Dialogue: 0,0:01:01.29,0:01:04.54,OPJP,,0,0,0,,最終問題　一発逆転
Dialogue: 0,0:01:04.54,0:01:06.42,OPJP,,0,0,0,,やっちゃいますか！
Dialogue: 0,0:01:06.42,0:01:08.13,OPJP,,0,0,0,,全問正解　全然無理よ
Dialogue: 0,0:01:08.13,0:01:09.67,OPJP,,0,0,0,,自分は何者？　もういいよ
Dialogue: 0,0:01:09.67,0:01:11.47,OPJP,,0,0,0,,この感情は正義だろうか？
Dialogue: 0,0:01:11.47,0:01:14.68,OPJP,,0,0,0,,教えておくれ
Dialogue: 0,0:01:14.68,0:01:18.06,OPJP,,0,0,0,,視聴率　気にし過ぎてた
Dialogue: 0,0:01:18.06,0:01:21.56,OPJP,,0,0,0,,今　曖昧な心を爆破する
Dialogue: 0,0:01:21.56,0:01:23.27,OPJP,,0,0,0,,○か×かじゃない
Dialogue: 0,0:01:23.27,0:01:25.06,OPJP,,0,0,0,,愛と平和と未来
Dialogue: 0,0:01:25.06,0:01:28.15,OPJP,,0,0,0,,マジで世界変えちゃう5秒前！
Dialogue: 0,0:00:02.61,0:00:05.90,OPCN,,0,0,0,,真的是改變世界的5秒前！
Dialogue: 0,0:00:10.99,0:00:13.03,OPCN,,0,0,0,,真夠青春 這個花壇
Dialogue: 0,0:00:13.03,0:00:14.79,OPCN,,0,0,0,,實際卻是 滿手汅泥
Dialogue: 0,0:00:14.79,0:00:16.45,OPCN,,0,0,0,,掛起黃色手帕
Dialogue: 0,0:00:16.45,0:00:17.83,OPCN,,0,0,0,,等待堅決說不
Dialogue: 0,0:00:18.33,0:00:19.17,OPCN,,0,0,0,,選擇自由開放
Dialogue: 0,0:00:19.17,0:00:20.04,OPCN,,0,0,0,,機關巧奪天工
Dialogue: 0,0:00:20.04,0:00:21.75,OPCN,,0,0,0,,即興犯禁 已讀無視
Dialogue: 0,0:00:21.75,0:00:23.59,OPCN,,0,0,0,,桃太郎先生 桃太郎先生
Dialogue: 0,0:00:23.59,0:00:25.26,OPCN,,0,0,0,,交涉連場 日日開會
Dialogue: 0,0:00:25.26,0:00:26.80,OPCN,,0,0,0,,Bang! 左邊來了裴隆
Dialogue: 0,0:00:26.80,0:00:28.34,OPCN,,0,0,0,,Bang! 右邊傳來世論
Dialogue: 0,0:00:28.34,0:00:30.05,OPCN,,0,0,0,,搖擺不停的意見
Dialogue: 0,0:00:30.05,0:00:32.01,OPCN,,0,0,0,,腦內齊喊 解放宣言
Dialogue: 0,0:00:32.01,0:00:33.72,OPCN,,0,0,0,,到底會發生甚麼呢？
Dialogue: 0,0:00:33.72,0:00:35.52,OPCN,,0,0,0,,動手吧！
Dialogue: 0,0:00:35.52,0:00:37.27,OPCN,,0,0,0,,每題都對 根本做不到
Dialogue: 0,0:00:37.27,0:00:38.85,OPCN,,0,0,0,,我是何人？根本不重要
Dialogue: 0,0:00:38.85,0:00:40.69,OPCN,,0,0,0,,這份感情是正義嗎
Dialogue: 0,0:00:40.69,0:00:42.36,OPCN,,0,0,0,,逆襲 Show Time
Dialogue: 0,0:00:42.36,0:00:44.11,OPCN,,0,0,0,,全是惡意 陷阱問題
Dialogue: 0,0:00:44.11,0:00:45.65,OPCN,,0,0,0,,誰是贏家 沒人在意
Dialogue: 0,0:00:45.65,0:00:48.57,OPCN,,0,0,0,,讓我教會你
Dialogue: 0,0:00:49.07,0:00:52.03,OPCN,,0,0,0,,收視率 太過在意了
Dialogue: 0,0:00:52.53,0:00:55.87,OPCN,,0,0,0,,現在 把曖昧之心爆破掉
Dialogue: 0,0:00:55.87,0:00:59.08,OPCN,,0,0,0,,真的是改變世界的5秒前！
Dialogue: 0,0:00:59.46,0:01:01.29,OPCN,,0,0,0,,崩壞Don't Mind 七國咁亂
Dialogue: 0,0:01:01.29,0:01:04.54,OPCN,,0,0,0,,最終問題 一擊逆轉
Dialogue: 0,0:01:04.54,0:01:06.42,OPCN,,0,0,0,,動手吧
Dialogue: 0,0:01:06.42,0:01:08.13,OPCN,,0,0,0,,每題都對 根本做不到
Dialogue: 0,0:01:08.13,0:01:09.67,OPCN,,0,0,0,,我是何人？根本不重要
Dialogue: 0,0:01:09.67,0:01:11.47,OPCN,,0,0,0,,這份感情是正義嗎
Dialogue: 0,0:01:11.47,0:01:14.68,OPCN,,0,0,0,,請告訴我啊
Dialogue: 0,0:01:14.68,0:01:18.06,OPCN,,0,0,0,,收視率 太過在意了
Dialogue: 0,0:01:18.06,0:01:21.56,OPCN,,0,0,0,,現在 把曖昧之心爆破掉
Dialogue: 0,0:01:21.56,0:01:23.27,OPCN,,0,0,0,,這不是○×的問題
Dialogue: 0,0:01:23.27,0:01:25.06,OPCN,,0,0,0,,愛與和平與未來
Dialogue: 0,0:01:25.06,0:01:28.15,OPCN,,0,0,0,,真的是改變世界的5秒前！
Comment: 0,0:22:11.98,0:22:12.02,EDJP,,0,0,0,,ED 正偽
Dialogue: 0,0:22:19.53,0:22:20.57,EDJP,,0,0,0,,また今日も始まった
Dialogue: 0,0:22:20.57,0:22:22.45,EDJP,,0,0,0,,しがみついて生き抜いた舞台だ
Dialogue: 0,0:22:22.45,0:22:24.49,EDJP,,0,0,0,,今度こそはと我を奮い立たせて
Dialogue: 0,0:22:24.49,0:22:26.53,EDJP,,0,0,0,,お決まりの茶番ぶっ飛ばした！
Dialogue: 0,0:22:26.53,0:22:28.54,EDJP,,0,0,0,,あぁそんなもんか　そんなとこかって
Dialogue: 0,0:22:28.54,0:22:30.08,EDJP,,0,0,0,,奥の手を隠して笑ってる
Dialogue: 0,0:22:30.08,0:22:32.12,EDJP,,0,0,0,,本当の姿を今教えてやるぜ
Dialogue: 0,0:22:32.12,0:22:33.87,EDJP,,0,0,0,,油断してばっか　そんじゃバイバイ！
Dialogue: 0,0:22:33.87,0:22:37.75,EDJP,,0,0,0,,{\c&HFA4B05&}嫌々になってまたどっか飛んでった
Dialogue: 0,0:22:37.75,0:22:38.84,EDJP,,0,0,0,,{\c&HFA4B05&}ズタボロになって
Dialogue: 0,0:22:38.84,0:22:40.84,EDJP,,0,0,0,,{\c&HFA4B05&}もどかしい世界だけを恨んでいた
Dialogue: 0,0:22:40.84,0:22:45.05,EDJP,,600,0,0,,{\c&HFA4B05&}もう嫌々になってまたどっか飛んでった
Dialogue: 0,0:22:45.05,0:22:46.64,EDJP,,0,0,0,,{\c&HFA4B05&}一体どうなっちまうんだって
Dialogue: 0,0:22:46.64,0:22:50.35,EDJP,,0,0,0,,{\c&HFA4B05&}救いようのない人の声を避けて塞いでいたい！
Dialogue: 0,0:22:51.60,0:22:54.94,EDJP,,0,0,0,,{\c&HFA4B05&}ため息が増えて仕方がないそんな僕の人生は
Dialogue: 0,0:22:54.94,0:22:57.15,EDJP,,0,0,0,,{\c&HFA4B05&}正当化する正義に縋っていくほど
Dialogue: 0,0:22:57.15,0:22:58.27,EDJP,,0,0,0,,{\c&HFA4B05&}お粗末な物じゃない
Dialogue: 0,0:22:58.27,0:23:00.53,EDJP,,300,0,0,,{\c&H005CE8&}世間と相反した除け者は
Dialogue: 0,0:23:00.53,0:23:02.61,EDJP,,300,0,0,,{\c&H005CE8&}怪物を見るような目をしていたんだ
Dialogue: 0,0:23:02.61,0:23:05.86,EDJP,,0,0,0,,{\c&H005CE8&}偽善だらけで救いはあるのか？
Dialogue: 0,0:23:07.28,0:23:08.78,EDJP,,0,0,0,,{\c&HCE00FF&}さぁその答えは
Dialogue: 0,0:23:08.78,0:23:11.04,EDJP,,0,0,0,,{\c&HCE00FF&}どこにも落ちてないようだ
Dialogue: 0,0:23:11.04,0:23:13.33,EDJP,,0,0,0,,{\c&HCE00FF&}ましてや世界のどこも転がっちゃいない
Dialogue: 0,0:23:13.33,0:23:14.46,EDJP,,0,0,0,,{\c&HCE00FF&}くしゃくしゃのゴミみたいに
Dialogue: 0,0:23:14.46,0:23:15.92,EDJP,,0,0,0,,{\c&HCE00FF&}さぁ始めようか！
Dialogue: 0,0:23:15.92,0:23:18.29,EDJP,,0,0,0,,{\c&HCE00FF&}くだらないネタバラシを
Dialogue: 0,0:23:18.29,0:23:20.42,EDJP,,0,0,0,,{\c&HCE00FF&}無駄にした数年の死闘を超えて
Dialogue: 0,0:23:20.42,0:23:22.05,EDJP,,0,0,0,,{\c&HCE00FF&}真っ当に生きていこうぜ！
Dialogue: 0,0:23:22.05,0:23:23.80,EDJP,,0,0,0,,{\c&HCE00FF&}抱えた怒りを超えて
Dialogue: 0,0:23:23.80,0:23:25.93,EDJP,,0,0,0,,{\c&HCE00FF&}僕はいつだって抗っていくんだ
Dialogue: 0,0:23:27.34,0:23:29.80,EDJP,,0,0,0,,{\c&H00BF0B&}吐き捨ててはまた拭って
Dialogue: 0,0:23:32.93,0:23:34.02,EDJP,,0,0,0,,{\c&H00BF0B&}また今日も始まった
Dialogue: 0,0:23:34.02,0:23:35.89,EDJP,,0,0,0,,{\c&H00BF0B&}しがみついて生き抜いた舞台だ
Dialogue: 0,0:23:35.89,0:23:37.90,EDJP,,0,0,0,,{\c&H00BF0B&}今度こそはと我を奮い立たせて
Dialogue: 0,0:23:37.90,0:23:39.73,EDJP,,0,0,0,,{\c&H00BF0B&}お決まりの茶番ぶっ飛ばした！
Dialogue: 1,0:22:19.53,0:22:20.57,EDCN,,0,0,0,,今天又開始了
Dialogue: 1,0:22:20.57,0:22:22.45,EDCN,,0,0,0,,拼盡一切存活下來的舞臺上
Dialogue: 1,0:22:22.45,0:22:24.49,EDCN,,0,0,0,,這次我定要大展拳腳
Dialogue: 1,0:22:24.49,0:22:26.53,EDCN,,0,0,0,,掃走預定好的鬧劇！
Dialogue: 1,0:22:26.53,0:22:28.54,EDCN,,0,0,0,,啊 就這樣嗎 只有這點程度
Dialogue: 1,0:22:28.54,0:22:30.08,EDCN,,0,0,0,,笑容之下藏着殺手鐧
Dialogue: 1,0:22:30.08,0:22:32.12,EDCN,,0,0,0,,讓你見識一下真正的形態
Dialogue: 1,0:22:32.12,0:22:33.87,EDCN,,0,0,0,,不斷犯錯 那就拜拜！
Dialogue: 1,0:22:33.87,0:22:37.75,EDCN,,0,0,0,,{\c&HFA4B05&}煩躁到極點 又再隨風飄散
Dialogue: 1,0:22:37.75,0:22:38.84,EDCN,,0,0,0,,{\c&HFA4B05&}變得殘破不堪
Dialogue: 1,0:22:38.84,0:22:40.84,EDCN,,0,0,0,,{\c&HFA4B05&}但保留對這惱人世界的憎恨
Dialogue: 1,0:22:40.84,0:22:45.05,EDCN,,600,0,0,,{\c&HFA4B05&}又再煩躁到極點 隨風飄散
Dialogue: 1,0:22:45.05,0:22:46.64,EDCN,,0,0,0,,{\c&HFA4B05&}這到底在發生甚麼鬼
Dialogue: 1,0:22:46.64,0:22:50.35,EDCN,,0,0,0,,{\c&HFA4B05&}堵住耳朵 遠離人群 不想聽到無可救藥的人的聲音！
Dialogue: 1,0:22:51.60,0:22:54.94,EDCN,,0,0,0,,{\c&HFA4B05&}嘆氣接嘆氣 無能為力 我這樣的人生
Dialogue: 1,0:22:54.94,0:22:57.15,EDCN,,0,0,0,,{\c&HFA4B05&}越是依賴將人生正當化的正義
Dialogue: 1,0:22:57.15,0:22:58.27,EDCN,,0,0,0,,{\c&HFA4B05&}我的人生就越無價值
Dialogue: 1,0:22:58.27,0:23:00.53,EDCN,,300,0,0,,{\c&H005CE8&}與世人背道而馳的邊緣人
Dialogue: 1,0:23:00.53,0:23:02.61,EDCN,,300,0,0,,{\c&H005CE8&}被人投以看待怪物的目光
Dialogue: 1,0:23:02.61,0:23:05.86,EDCN,,0,0,0,,{\c&H005CE8&}充滿偽善的人生能得到救贖？
Dialogue: 1,0:23:07.28,0:23:08.78,EDCN,,0,0,0,,{\c&HCE00FF&}這個答案
Dialogue: 1,0:23:08.78,0:23:11.04,EDCN,,0,0,0,,{\c&HCE00FF&}好像從未出現過
Dialogue: 1,0:23:11.04,0:23:13.33,EDCN,,0,0,0,,{\c&HCE00FF&}要去哪找從未出現在世上的東西
Dialogue: 1,0:23:13.33,0:23:14.46,EDCN,,0,0,0,,{\c&HCE00FF&}如同亂糟糟的垃圾
Dialogue: 1,0:23:14.46,0:23:15.92,EDCN,,0,0,0,,{\c&HCE00FF&}來開始吧！
Dialogue: 1,0:23:15.92,0:23:18.29,EDCN,,0,0,0,,{\c&HCE00FF&}無聊至極的劇透
Dialogue: 1,0:23:18.29,0:23:20.42,EDCN,,0,0,0,,{\c&HCE00FF&}跨過數年來毫無意義的死鬥
Dialogue: 1,0:23:20.42,0:23:22.05,EDCN,,0,0,0,,{\c&HCE00FF&}堂堂正正地活下去！
Dialogue: 1,0:23:22.05,0:23:23.80,EDCN,,0,0,0,,{\c&HCE00FF&}超越心中的憤怒
Dialogue: 1,0:23:23.80,0:23:25.93,EDCN,,0,0,0,,{\c&HCE00FF&}我會一直反抗到底
Dialogue: 1,0:23:27.34,0:23:29.80,EDCN,,0,0,0,,{\c&H00BF0B&}口出狂言 又不斷收回
Dialogue: 1,0:23:32.93,0:23:34.02,EDCN,,0,0,0,,{\c&H00BF0B&}今天又開始了
Dialogue: 1,0:23:34.02,0:23:35.89,EDCN,,0,0,0,,{\c&H00BF0B&}拼盡一切存活下來的舞臺上
Dialogue: 1,0:23:35.89,0:23:37.90,EDCN,,0,0,0,,{\c&H00BF0B&}這次我定要大展拳腳
Dialogue: 1,0:23:37.90,0:23:39.73,EDCN,,0,0,0,,{\c&H00BF0B&}掃走預定好的鬧劇！
Dialogue: 0,0:01:02.00,0:01:02.00,EDJP,,0,0,0,,
